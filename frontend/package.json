{
  "name": "training-dashboard-frontend",
  "version": "1.0.0",
  "description": "Training Dashboard - Professional cycling performance analytics",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "pkill -f \"frontend/node_modules/.bin/vite\" || true; rm -rf node_modules/.vite; vite --host 127.0.0.1 --port 8080 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite preview --port 8080",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "unity:preflight": "bash ../scripts/unity/preflight-path-check.sh",
    "unity:sync": "node scripts/sync-unity-build.mjs",
    "unity:verify": "node scripts/verify-unity-build.mjs",
    "unity:manifest:local": "node ../scripts/unity/publish-build.mjs --target local",
    "unity:publish:s3": "node ../scripts/unity/publish-build.mjs --target s3",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/browser": "^10.21.0",
    "@mapbox/polyline": "^1.2.1",
    "chart.js": "^4.5.0",
    "feather-icons": "^4.29.2",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.563.0",
    "mapbox-gl": "^3.17.0",
    "plotly.js-dist-min": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@babel/core": "^7.28.6",
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "terser": "^5.44.1",
    "vite": "^5.4.21",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "engines": {
    "node": ">=18 <23"
  }
}
